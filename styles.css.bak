    --color-yellow-400: oklch(.852 .199 91.936);
    --color-emerald-400: oklch(.765 .177 163.223);
    --color-emerald-600: oklch(.596 .145 163.225);
    --color-cyan-300: oklch(.865 .127 207.078);
    --color-cyan-400: #00f3ff;
    --color-cyan-600: #00a8b0;
    --color-cyan-700: #00838a;
    --color-cyan-800: #006066;
    --color-cyan-900: #004044;
    --color-cyan-950: #002022;
    --color-blue-400: #3b82f6;
    --color-blue-600: #2563eb;
    --color-purple-400: #d946ef;
    --color-purple-600: #9333ea;
    --color-slate-300: #cbd5e1;
    --color-slate-400: #94a3b8;
    --color-slate-700: #1e293b;
    --color-slate-800: #0f172a;
    --color-slate-900: #020617;
    --color-slate-950: #000000;
    --color-black: #000;
    --color-white: #fff;
    --spacing: .25rem;
    --container-lg: 32rem;
    --container-2xl: 42rem;
    --text-xs: .75rem;
