@keyframes enter {
  from {
    opacity: var(--tw-enter-opacity, 1);
    transform: translate3d(var(--tw-enter-translate-x, 0), var(--tw-enter-translate-y, 0), 0) scale3d(var(--tw-enter-scale, 1), var(--tw-enter-scale, 1), var(--tw-enter-scale, 1)) rotate(var(--tw-enter-rotate, 0));
  }
}

@keyframes exit {
  to {
    opacity: var(--tw-exit-opacity, 1);
    transform: translate3d(var(--tw-exit-translate-x, 0), var(--tw-exit-translate-y, 0), 0) scale3d(var(--tw-exit-scale, 1), var(--tw-exit-scale, 1), var(--tw-exit-scale, 1)) rotate(var(--tw-exit-rotate, 0));
  }
}

/* Tweak: reduce hero CTA size slightly */
.bouton-hero {
  padding-inline: calc(var(--spacing) * 10); /* ~2.5rem */
  padding-block: calc(var(--spacing) * 4);   /* ~1rem */
  font-size: 1.0625rem; /* slightly larger than base but reduced */
  font-weight: 600;
  border-radius: calc(var(--radius) + 2px);
  text-decoration: none;
}

@media (width >=64rem) {
  .bouton-hero {
    padding-inline: calc(var(--spacing) * 12); /* ~3rem */
    padding-block: calc(var(--spacing) * 5);   /* ~1.25rem */
    font-size: 1.125rem;
  }
}

/* Smooth hover transition */
.bouton-hero:hover {
  transition: background-color .15s ease, color .15s ease;
}
/* Custom Animations for Leaderboard */
@keyframes glissementHaut {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes lueurPulsante {
  0%, 100% { box-shadow: 0 0 15px -5px rgba(6, 182, 212, 0.5); }
  50% { box-shadow: 0 0 25px -5px rgba(6, 182, 212, 0.8); }
}

.animation-glissement-haut {
  animation: glissementHaut 0.6s ease-out forwards;
  opacity: 0; /* Start hidden */
}

.delay-100 { animation-delay: 100ms; }
.delay-200 { animation-delay: 200ms; }
.delay-300 { animation-delay: 300ms; }
.delay-400 { animation-delay: 400ms; }
.delay-500 { animation-delay: 500ms; }

.effet-lueur {
  animation: lueurPulsante 3s infinite;
}

.fond-grille-cyber {
  background-image: radial-gradient(circle at center, rgba(6, 182, 212, 0.1) 0%, transparent 70%),
                    linear-gradient(rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.9)),
                    repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(6, 182, 212, 0.05) 50px),
                    repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(6, 182, 212, 0.05) 50px);
  background-size: 100% 100%, 100% 100%, 100px 100px, 100px 100px;
}


/* Missing utility classes */
.-top-4 {
  top: calc(var(--spacing) * -4);
}
.-right-2 {
  right: calc(var(--spacing) * -2);
}

@media (width >= 48rem) {
  .md\:grid-cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}


/* More missing utility classes */
.pl-9 {
  padding-left: calc(var(--spacing) * 9);
}
.left-3 {
  left: calc(var(--spacing) * 3);
}
.top-1\/2 {
  top: 50%;
}
.-translate-y-1\/2 {
  --tw-translate-y: -50%;
  translate: var(--tw-translate-x) var(--tw-translate-y);
}
.w-56 {
  width: calc(var(--spacing) * 56);
}

/* --- CLEAN LIGHT THEME OVERRIDES --- */

:root {
    --bg-primary: #ffffff;
    --bg-secondary: #f8fafc;
    --text-main: #0f172a;
    --text-muted: #475569;
    --accent-color: #2563eb; /* Royal Blue */
    --border-color: #e2e8f0;
}

body {
    background-color: var(--bg-primary) !important;
    background-image: none !important;
    color: var(--text-main) !important;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

/* Invert text colors for light mode */
.text-white, .text-slate-200, .text-slate-300 {
    color: var(--text-main) !important;
}

.text-slate-400, .text-slate-500 {
    color: var(--text-muted) !important;
}

/* Headers */
h1, h2, h3, h4, h5, h6 {
    color: #1e293b !important;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: none; /* Remove uppercase */
    background: none !important; /* Remove gradients */
    -webkit-text-fill-color: initial !important;
    text-shadow: none !important;
}

/* Navbar & Footer */
header, footer {
    background-color: rgba(255, 255, 255, 0.95) !important;
    border-color: var(--border-color) !important;
    backdrop-filter: blur(8px);
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

/* Cards */
.bg-slate-800\/50, .bg-slate-900\/50, .bg-slate-950\/50, 
.bg-slate-900, .bg-slate-950, .bg-slate-800, .bg-slate-900\/80 {
    background-color: #ffffff !important;
    border: 1px solid var(--border-color) !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    border-radius: 12px;
    backdrop-filter: none !important;
}

.bg-slate-800\/50:hover, .bg-slate-900\/80:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1);
    border-color: var(--accent-color) !important;
}

/* Buttons */
.bg-cyan-600 {
    background: var(--accent-color) !important;
    color: #ffffff !important;
    border-radius: 8px;
    box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2);
    border: none;
    font-weight: 600;
    text-transform: none;
    letter-spacing: normal;
}

.bg-cyan-600:hover {
    background: #1d4ed8 !important; /* Darker blue */
    box-shadow: 0 4px 8px rgba(37, 99, 235, 0.3);
    transform: translateY(-1px);
}

/* Inputs */
input, select, textarea {
    background-color: #ffffff !important;
    border: 1px solid #cbd5e1 !important;
    color: #0f172a !important;
    border-radius: 8px;
    font-family: inherit !important;
}

input:focus, select:focus, textarea:focus {
    border-color: var(--accent-color) !important;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1) !important;
    outline: none;
}

/* Accents */
.text-cyan-400 {
    color: var(--accent-color) !important;
    text-shadow: none !important;
}

.border-cyan-600, .border-cyan-900, .border-slate-700, .border-slate-800 {
    border-color: var(--border-color) !important;
}

/* Icons */
i[data-lucide] {
    stroke-width: 2px;
}

/* Remove specific dark mode overrides */
.fond-grille-cyber {
    background-image: none !important;
}

/* Scrollbar */
::-webkit-scrollbar {
    width: 10px;
}
::-webkit-scrollbar-track {
    background: #f1f5f9;
}
::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 5px;
    border: 2px solid #f1f5f9;
}
::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
}

/* Specific fixes for hero section text visibility */
.text-slate-400 {
    color: #64748b !important;
}

/* Fix for the "Top 1" badge in leaderboard */
.bg-amber-500 {
    color: #fff !important;
}
.text-amber-300 {
    color: #d97706 !important; /* Darker amber for light mode */
}
.text-amber-200 {
    color: #78350f !important;
}

/* Fix for mobile menu */
#menu-mobile {
    background-color: #ffffff !important;
    border-top: 1px solid var(--border-color) !important;
}

